{
    "name": "seosi/seo-structure-inspector",
    "description": "Inspects HTML structure, keyword usage, Schema.org, readability, meta tags, LLMs/GEO, AEO, Core Web Vitals, and links.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "BaloaStructureAuditorSEO\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BaloaStructureAuditorSEO\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5"
    },
    "config": {
        "platform-check": false
    }
}
